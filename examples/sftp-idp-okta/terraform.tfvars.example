aws_region     = "us-east-1" 
name_prefix    = "sftp-okta" 
 
# Okta Configuration 
okta_domain     = "your-org.okta.com" 
okta_user_email = "sftpuser@example.com" 
 
# Optional: Enable MFA 
# okta_mfa_required     = true 
# okta_mfa_token_length = 6 
 
# Optional: S3 encryption with KMS (default is AES256) 
# s3_encryption_algorithm = "aws:kms" 
# s3_kms_key_id           = "arn:aws:kms:us-east-1:123456789012:key/your-key-id" 
 
# Optional: Restrict IP access for default users 
# default_user_ipv4_allow_list = ["10.0.0.0/8"] 