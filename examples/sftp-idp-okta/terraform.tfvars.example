# ============================================================================
# AWS Configuration
# ============================================================================
aws_region  = "us-east-1"
name_prefix = "sftp-okta-example"

# ============================================================================
# Okta Configuration
# ============================================================================
okta_domain   = "your-org-name.okta.com"      # REQUIRED: Full Okta domain (e.g., "dev-12345.okta.com")

# Required: Email address of the Okta user for SFTP access
okta_user_email = "user@example.com"  # Your Okta user's email address

# Optional: Okta application client ID for SFTP authentication
# okta_app_client_id = "0oax..."

# ============================================================================
# MFA Configuration (Optional)
# ============================================================================

# Enable MFA for enhanced security
# When enabled, users must append their 6-digit TOTP code to their password
# Example: if password is "mypassword" and TOTP code is "123456", enter "mypassword123456"
# okta_mfa_required = true

# MFA token length (default: 6 digits for Google Authenticator, Okta Verify, etc.)
# okta_mfa_token_length = 6

# ============================================================================
# Infrastructure Configuration
# ============================================================================
# enable_deletion_protection = false  # Set to true in production
# provision_api              = false  # Set to true to use API Gateway instead of Lambda

# Optional: Tags for all resources
# tags = {
#   Environment = "demo"
#   Project     = "transfer-family-okta"
# }
